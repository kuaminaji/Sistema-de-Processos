# Configuração do Servidor
PORT=3000
NODE_ENV=development

# Banco de Dados
DB_PATH=./data/database.sqlite

# Segurança
TRUST_PROXY=1
COOKIE_SECURE=false
SESSION_SECRET=change-this-to-a-random-secret-in-production

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Políticas de Senha
PASSWORD_EXPIRY_DAYS=90
PASSWORD_HISTORY_COUNT=5

# Brute Force Protection
BRUTE_FORCE_BASE_MINUTES=5
BRUTE_FORCE_MAX_MINUTES=120

# Admin Bootstrap (primeira execução)
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=admin123

# HTTPS LAN (configurar quando usar proxy reverso)
# COOKIE_SECURE=true quando usar HTTPS
# TRUST_PROXY=1 quando atrás de nginx/caddy
