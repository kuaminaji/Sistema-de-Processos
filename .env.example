# Configuração do Servidor
PORT=3000
NODE_ENV=development

# Banco de Dados
DB_PATH=./data/database.sqlite

# Segurança
TRUST_PROXY=1
COOKIE_SECURE=false
SESSION_SECRET=change-this-to-a-random-secret-in-production

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Políticas de Senha
PASSWORD_EXPIRY_DAYS=90
PASSWORD_HISTORY_COUNT=5

# Brute Force Protection
BRUTE_FORCE_MAX_ATTEMPTS=10
BRUTE_FORCE_BASE_MINUTES=5
BRUTE_FORCE_MAX_MINUTES=120

# Admin Bootstrap (primeira execução)
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=Admin@123456

# Aplicacao
APP_URL=http://127.0.0.1:3000

# Atualizacao desktop
# AUTO_UPDATE_URL=https://seu-servidor/releases
# AUTO_UPDATE_RELEASES_URL=https://seu-servidor/releases
# AUTO_UPDATE_CHANNEL=stable
# AUTO_UPDATE_AUTO_CHECK=true

# SMTP opcional para recuperar senha por email
# SMTP_HOST=smtp.seudominio.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=usuario
# SMTP_PASS=senha
# SMTP_FROM="Sistema de Processos <no-reply@seudominio.com>"

# HTTPS LAN (configurar quando usar proxy reverso)
# COOKIE_SECURE=true quando usar HTTPS
# TRUST_PROXY=1 quando atrás de nginx/caddy
